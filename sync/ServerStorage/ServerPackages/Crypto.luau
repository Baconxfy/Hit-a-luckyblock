--[[ 
    READ ME:
    Put this inside ServerStorage.
	
    Description:
	Crypto is encryption and decryption module for TOKENS, API_KEYS, and more...
	Crypto uses a KEY to encrypt or decrypt, this KEY is randomly generated per server.
	
	Main Functions:
	Crypto:encrypt(text) --returns the encrypted text
	Crypto:decrypt(text) --returns the decrypted (real) text
	
	Recomendation:
	Use a StringValue with the real text value you want to encrypt, then 
	encrypt the value of the StringValue and change it, like this:
	
	Example:
	```
		local Crypto = require(game.ServerStorage.MODULE_NAME)
		local StringValueHere = StringValue_Path_Here
		StringValueHere.Value = Crypto:encrypt(StringValueHere.Value)
		print(StringValueHere.Value)
		
		-- Now the value of the StringValue `StringValueHere` was encrypted
		-- You can get the real value by using Crypto:decrypt(text)
		
		print( Crypto:decrypt(StringValueHere.Value) )
	```
]]


local HttpService = game:GetService("HttpService")
local Crypto      = {}
local bit32       = bit32

-- ──────────────────────────────────────────────────────────────────
--  CONFIGURATION (server-only!)
-- ──────────────────────────────────────────────────────────────────
Crypto.KEY = HttpService:GenerateGUID(false):gsub("-", ""):sub(1, 32)                  
if #Crypto.KEY  < 8 then
	Crypto.KEY = Crypto.KEY .. string.rep("0", 8 - #Crypto.KEY)
end

-- ──────────────────────────────────────────────────────────────────
-- 1) RC4 CORE
-- ──────────────────────────────────────────────────────────────────
local function rc4_init(key)
	local S, j = {}, 0
	local len = #key
	for i = 0, 255 do
		S[i] = i
	end
	for i = 0, 255 do
		j = (j + S[i] + key:byte((i % len) + 1)) % 256
		S[i], S[j] = S[j], S[i]
	end
	return S, 0, 0
end

local function rc4_crypt(key, data)
	local S, i, j = rc4_init(key)
	local out = {}
	for idx = 1, #data do
		i = (i + 1) % 256
		j = (j + S[i])    % 256
		S[i], S[j] = S[j], S[i]
		local K = S[(S[i] + S[j]) % 256]
		out[idx] = string.char(bit32.bxor(data:byte(idx), K))
	end
	return table.concat(out)
end

-- ──────────────────────────────────────────────────────────────────
-- 2) BASE64
-- ──────────────────────────────────────────────────────────────────
local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local b64inv    = {}
for i = 1, #b64chars do
	b64inv[b64chars:sub(i,i)] = i-1
end

function Crypto.base64_encode(data)
	local res = {}
	local pad = (#data % 3 ~= 0) and (3 - #data % 3) or 0
	data = data .. string.rep("\0", pad)
	for i = 1, #data, 3 do
		local a, b, c = data:byte(i, i+2)
		local n = a * 65536 + b * 256 + c
		local c1 = bit32.band(bit32.rshift(n, 18), 0x3F)
		local c2 = bit32.band(bit32.rshift(n, 12), 0x3F)
		local c3 = bit32.band(bit32.rshift(n,  6), 0x3F)
		local c4 = bit32.band(n,                0x3F)
		res[#res+1] = b64chars:sub(c1+1, c1+1)
		res[#res+1] = b64chars:sub(c2+1, c2+1)
		res[#res+1] = b64chars:sub(c3+1, c3+1)
		res[#res+1] = b64chars:sub(c4+1, c4+1)
	end
	if pad > 0 then
		for _ = 1, pad do
			res[#res - (_-1)] = "="
		end
	end
	return table.concat(res)
end

function Crypto.base64_decode(str)
	local s = str:gsub("%s+", "")
	local pad = 0
	s = s:gsub("=+$", function(e) pad = #e; return "" end)
	local out = {}
	for i = 1, #s, 4 do
		local v1 = b64inv[s:sub(i  ,i  )] or 0
		local v2 = b64inv[s:sub(i+1,i+1)] or 0
		local v3 = b64inv[s:sub(i+2,i+2)] or 0
		local v4 = b64inv[s:sub(i+3,i+3)] or 0
		local n = bit32.bor(
			bit32.lshift(v1, 18),
			bit32.lshift(v2, 12),
			bit32.lshift(v3,  6),
			v4
		)
		out[#out+1] = string.char(bit32.rshift(n, 16) % 256)
		out[#out+1] = string.char(bit32.rshift(n,  8) % 256)
		out[#out+1] = string.char(n % 256)
	end
	local decoded = table.concat(out)
	if pad > 0 then
		return decoded:sub(1, -pad - 1)
	end
	return decoded
end

-- ──────────────────────────────────────────────────────────────────
-- 3) PUBLIC METHODS
-- ──────────────────────────────────────────────────────────────────

--- Encrypts the given plaintext and returns a Base64 string.
-- @string plaintext  UTF-8 text you want to hide.
-- @treturn string     Encrypted Base64 payload.
function Crypto:encrypt(plaintext)
	assert(type(plaintext) == "string" and #plaintext > 0, "Invalid plaintext")
	local cipher = rc4_crypt(self.KEY, plaintext)
	return self.base64_encode(cipher)
end

--- Decrypts a Base64 payload previously generated by :encrypt.
-- @string cipherB64  Base64 string from :encrypt.
-- @treturn string     Original plaintext.
function Crypto:decrypt(cipherB64)
	assert(type(cipherB64) == "string" and #cipherB64 > 0, "Invalid ciphertext")
	local raw = self.base64_decode(cipherB64)
	return rc4_crypt(self.KEY, raw)
end

return Crypto
